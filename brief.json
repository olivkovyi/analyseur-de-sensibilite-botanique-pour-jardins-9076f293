   cursor: pointer;\n            transition: background-color 0.3s ease;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            align-self: flex-start;\n        }\n\n        button#tool-submit:hover {\n            background-color: #588157;\n        }\n\n        #tool-result {\n            margin-top: 1.5rem;\n            padding-top: 1.5rem;\n            border-top: 1px dashed var(--color-accent);\n            font-size: 0.95rem;\n        }\n\n        #tool-result h3 {\n            font-family: var(--font-display);\n            color: var(--color-primary);\n            font-size: 1.4rem;\n            margin-top: 0;\n            margin-bottom: 1rem;\n            text-transform: uppercase;\n        }\n\n        #tool-result div {\n            margin-bottom: 1rem;\n            padding: 1rem;\n            background-color: #E8E8E4;\n            border-left: 3px solid var(--color-accent);\n            border-radius: 4px;\n        }\n\n        #tool-result div strong {\n            color: var(--color-primary);\n            display: block;\n            margin-bottom: 0.5rem;\n            font-family: var(--font-display);\n        }\n\n        .call-to-action {\n            text-align: center;\n            padding: 3rem 5%;\n            background-color: var(--color-accent);\n            color: var(--color-text);\n        }\n\n        .call-to-action h2 {\n            font-family: var(--font-display);\n            font-size: 2.2rem;\n            margin-bottom: 1.5rem;\n            color: var(--color-primary);\n        }\n\n        .call-to-action p {\n            max-width: 700px;\n            margin: 0 auto 2rem;\n            font-size: 1.1rem;\n        }\n\n        .call-to-action button {\n            background-color: var(--color-primary);\n            color: var(--color-secondary);\n            padding: 1.2rem 2.5rem;\n            border: none;\n            border-radius: 5px;\n            font-family: var(--font-display);\n            font-size: 1.2rem;\n            cursor: pointer;\n            transition: background-color 0.3s ease;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            font-weight: bold;\n        }\n\n        .call-to-action button:hover {\n            background-color: #588157;\n        }\n\n        footer {\n            background-color: var(--color-primary);\n            color: var(--color-secondary);\n            padding: 2rem 5%;\n            text-align: center;\n            font-size: 0.9rem;\n        }\n\n        footer h3 {\n            font-family: var(--font-display);\n            font-size: 1.5rem;\n            margin-top: 0;\n            margin-bottom: 1rem;\n            text-transform: uppercase;\n        }\n\n        footer p {\n            max-width: 800px;\n            margin: 0.5rem auto;\n        }\n\n        @media (max-width: 768px) {\n            header h1 {\n                font-size: 2rem;\n            }\n            .panel {\n                padding: 1.5rem;\n            }\n            .panel h2 {\n                font-size: 1.5rem;\n            }\n            .call-to-action h2 {\n                font-size: 1.8rem;\n            }\n        }\n    </style>\n    <meta name=\"robots\" content=\"index, follow\">\n    <link rel=\"canonical\" href=\"https://analyseur-de-sensibilite-botanique-pour-jardins-9076f293.onrender.com\">\n    <meta property=\"og:title\" content=\"Analyseur de Sensibilité Botanique pour Jardins Urbains\">\n    <meta property=\"og:description\" content=\"Déterminez les plantes idéales pour votre espace extérieur en analysant l\">\n    <meta property=\"og:url\" content=\"https://analyseur-de-sensibilite-botanique-pour-jardins-9076f293.onrender.com\">\n    <meta property=\"og:type\" content=\"website\">\n    <script type=\"application/ld+json\">{\"@context\": \"https://schema.org\", \"@type\": \"WebApplication\", \"name\": \"Analyseur de Sensibilité Botanique pour Jardins Urbains\", \"description\": \"Déterminez les plantes idéales pour votre espace extérieur en analysant l\", \"url\": \"https://analyseur-de-sensibilite-botanique-pour-jardins-9076f293.onrender.com\", \"applicationCategory\": \"UtilityApplication\", \"operatingSystem\": \"Web Browser\"}</script>\n</head>\n<body data-site-slug=\"analyseur-de-sensibilite-botanique-pour-jardins-9076f293\" data-runtime-mode=\"analysis_tool\">\n    <header>\n        <h1>Analyseur de Sensibilité Botanique</h1>\n        <p>Déterminez les plantes idéales pour votre espace extérieur en analysant l'ensoleillement, le type de sol et les microclimats de votre jardin urbain. Optimisez vos plantations avec notre approche \"Mechanical Botanical\".</p>\n    </header>\n\n    <main>\n        <section class=\"panel\">\n            <h2>Paramétrez Votre Écosystème Urbain</h2>\n            <p>Fournissez-nous quelques détails sur votre espace. Notre algorithme \"botanico-mécanique\" vous guidera vers les choix les plus adaptés.</p>\n            <form id=\"tool-form\">\n                <label for=\"ensoleillement\">Niveau d'ensoleillement quotidien :</label>\n                <select id=\"ensoleillement\" name=\"ensoleillement\" required>\n                    <option value=\"\">Sélectionnez une option</option>\n                    <option value=\"plein-soleil\">Plein soleil (6h+ par jour)</option>\n                    <option value=\"mi-ombre\">Mi-ombre (3-6h par jour)</option>\n                    <option value=\"ombre\">Ombre (moins de 3h par jour)</option>\n                </select>\n\n                <label for=\"type-sol\">Type de sol dominant :</label>\n                <select id=\"type-sol\" name=\"type-sol\" required>\n                    <option value=\"\">Sélectionnez une option</option>\n                    <option value=\"argileux\">Argileux (lourd, retient l'eau)</option>\n                    <option value=\"sableux\">Sableux (léger, drainant)</option>\n                    <option value=\"limoneux\">Limoneux (équilibré, fertile)</option>\n                    <option value=\"calcaire\">Calcaire (alcalin)</option>\n                    <option value=\"acide\">Acide (pH bas)</option>\n                </select>\n\n                <label for=\"microclimat\">Observations sur le microclimat de votre jardin (vents, humidité, zones chaudes/froides) :</label>\n                <textarea id=\"microclimat\" name=\"microclimat\" rows=\"4\" placeholder=\"Ex: 'Mur exposé au sud retenant la chaleur', 'Couloir de vent fréquent', 'Zone très humide près d'un point d'eau'...\"></textarea>\n\n                <button type=\"submit\" id=\"tool-submit\">Analyser Mon Jardin</button>\n            </form>\n        </section>\n\n        <section class=\"panel\" id=\"tool-result\">\n            <h2 id=\"result-headline\">Vos Recommandations Botaniques</h2>\n            <p>Vos plantes idéales apparaîtront ici. Préparez-vous à transformer votre espace !</p>\n            <!-- Results will be injected here -->\n        </section>\n    </main>\n\n    <section class=\"call-to-action\">\n        <h2>Passez du Vert au Vibrant.</h2>\n        <p>Débloquez le potentiel caché de votre balcon, terrasse ou rebord de fenêtre. Notre analyse précise vous évite les déceptions et vous mène directement au succès botanique. Créez un havre de paix personnalisé et durable.</p>\n        <button data-affiliate-slot=\"promo-top-button\">Découvrir nos Packs de Graines</button>\n    </section>\n\n    <footer>\n        <h3>Jardiner en Ville, Simplifié.</h3>\n        <p>Chez \"Mechanical Botanical\", nous croyons que chaque espace urbain mérite de s'épanouir. Notre outil est conçu pour les citadins passionnés, offrant une synergie parfaite entre la rigueur technologique et la splendeur naturelle. Plantez malin, récoltez la beauté.</p>\n        <p>&copy; 2023 Mechanical Botanical. Tous droits réservés.</p>\n        <p>\n            <a href=\"#\" style=\"color: var(--color-secondary); text-decoration: none; margin: 0 10px;\">Mentions Légales</a> |\n            <a href=\"#\" style=\"color: var(--color-secondary); text-decoration: none; margin: 0 10px;\">Confidentialité</a>\n        </p>\n\n        <!-- SEO Section for France -->\n        <div style=\"margin-top: 3rem; text-align: left; font-size: 0.8rem; line-height: 1.8; color: #D4D4CE;\">\n            <h3>Optimiser Votre Jardin Urbain : Conseils et Solutions</h3>\n            <p>Vous recherchez des <strong style=\"color: var(--color-secondary);\">idées de plantes pour balcon en ville</strong> ou comment <strong style=\"color: var(--color-secondary);\">aménager un petit jardin sur terrasse</strong> ? Notre analyseur vous aide à choisir les meilleures espèces végétales adaptées à votre <strong style=\"color: var(--color-secondary);\">ensoleillement de jardin urbain</strong> et au <strong style=\"color: var(--color-secondary);\">type de sol de jardinière</strong>. Que vous soyez un <strong style=\"color: var(--color-secondary);\">jardinier débutant en appartement</strong> ou un expert en <strong style=\"color: var(--color-secondary);\">permaculture urbaine</strong>, découvrez des <strong style=\"color: var(--color-secondary);\">plantes résistantes pour microclimat citadin</strong>. Trouvez des <strong style=\"color: var(--color-secondary);\">fleurs pour balcon plein soleil</strong>, des <strong style=\"color: var(--color-secondary);\">aromatiques pour zone ombragée</strong>, ou des <strong style=\"color: var(--color-secondary);\">légumes adaptés au sol argileux de ville</strong>. Notre outil est votre allié pour un <strong style=\"color: var(--color-secondary);\">jardin potager sur balcon productif</strong> et un <strong style=\"color: var(--color-secondary);\">coin de verdure en ville sans entretien</strong> excessif. Évitez les erreurs courantes et apprenez à <strong style=\"color: var(--color-secondary);\">reconnaître le sol de votre jardin urbain</strong> pour un <strong style=\"color: var(--color-secondary);\">choix de plantes optimisé</strong>. Que faire pousser sur un <strong style=\"color: var(--color-secondary);\">balcon exposé nord</strong> ou un <strong style=\"color: var(--color-secondary);\">jardin sur toit en ville</strong> ? \"Mechanical Botanical\" vous offre des réponses précises pour chaque situation.</p>\n        </div>\n    </footer>\n\n    <script>\n        document.getElementById('tool-form').addEventListener('submit', function(event) {\n            event.preventDefault();\n\n            const ensoleillement = document.getElementById('ensoleillement').value;\n            const typeSol = document.getElementById('type-sol').value;\n            const microclimat = document.getElementById('microclimat').value.toLowerCase();\n            const resultDiv = document.getElementById('tool-result');\n            let recommendations = [];\n\n            // Logic for plant recommendations\n            if (!ensoleillement || !typeSol) {\n                recommendations.push({\n                    category: \"Attention\",\n                    plants: [\"Veuillez sélectionner toutes les options pour obtenir une recommandation complète.\"],\n                    description: \"Les champs 'Ensoleillement' et 'Type de sol' sont obligatoires.\"\n                });\n            } else {\n                // Base recommendations\n                if (ensoleillement === 'plein-soleil') {\n                    recommendations.push({\n                        category: \"Plein Soleil\",\n                        plants: [\"Lavande\", \"Romarin\", \"Thym\", \"Géranium\", \"Sedum\", \"Tomates (variétés naines)\", \"Capucines\"],\n                        description: \"Ces plantes aiment la lumière directe et tolèrent bien la chaleur.\"\n                    });\n                } else if (ensoleillement === 'mi-ombre') {\n                    recommendations.push({\n                        category: \"Mi-Ombre\",\n                        plants: [\"Menthe\", \"Persil\", \"Fougères\", \"Hostas\", \"Impatiens\", \"Bégonias\", \"Fraisiers\"],\n                        description: \"Idéales pour les zones recevant quelques heures de soleil le matin ou le soir.\"\n                    });\n                } else if (ensoleillement === 'ombre') {\n                    recommendations.push({\n                        category: \"Ombre\",\n                        plants: [\"Lierre\", \"Mousse\", \"Fougères (certaines)\", \"Primevères\", \"Hortensias (certaines variétés)\", \"Pervenches\"],\n                        description: \"Parfaites pour les recoins peu lumineux, sous les arbres ou les balcons exposés nord.\"\n                    });\n                }\n\n                if (typeSol === 'argileux') {\n                    recommendations.push({\n                        category: \"Sol Argileux\",\n                        plants: [\"Rosiers\", \"Groseilliers\", \"Choux\", \"Haricots\", \"Poireaux\"],\n                        description: \"Ce sol retient bien l'eau et les nutriments, mais nécessite un bon drainage.\"\n                    });\n                } else if (typeSol === 'sableux') {\n                    recommendations.push({\n                        category: \"Sol Sableux\",\n                        plants: [\"Carottes\", \"Pommes de terre\", \"Radis\", \"Cactus\", \"Plantes grasses\", \"Graminées ornementales\"],\n                        description: \"Excellent drainage, mais nécessite un apport régulier en compost pour retenir l'eau et les nutriments.\"\n                    });\n                } else if (typeSol === 'limoneux') {\n                    recommendations.push({\n                        category: \"Sol Limoneux\",\n                        plants: [\"Presque toutes les plantes ! Rosiers, légumes feuilles, fleurs annuelles...\"],\n                        description: \"Le sol idéal : fertile, retient l'eau et les nutriments tout en étant bien drainé.\"\n                    });\n                } else if (typeSol === 'calcaire') {\n                    recommendations.push({\n                        category: \"Sol Calcaire\",\n                        plants: [\"Buis\", \"Lilas\", \"Cistes\", \"Lavande\", \"Iris\", \"Chèvrefeuille\"],\n                        description: \"Préférer les plantes qui tolèrent ou apprécient un pH élevé.\"\n                    });\n                } else if (typeSol === 'acide') {\n                    recommendations.push({\n                        category: \"Sol Acide\",\n                        plants: [\"Hortensias (bleus)\", \"Rhododendrons\", \"Azalées\", \"Camélias\", \"Bruyères\", \"Fougères\"],\n                        description: \"Choisissez des plantes acidophiles qui s'épanouissent dans un pH bas.\"\n                    });\n                }\n\n                // Microclimate adjustments\n                if (microclimat.includes('vent')) {\n                    recommendations.push({\n                        category: \"Protection contre le Vent\",\n                        plants: [\"Généralement des plantes basses et robustes : Sedum, Graminées naines, Pensées, Oeillet\"],\n                        description: \"Prévoyez des brise-vents ou des plantes résilientes au vent.\"\n                    });\n                }\n                if (microclimat.includes('chaleur') || microclimat.includes('mur exposé sud')) {\n                    recommendations.push({\n                        category: \"Zones Chaudes\",\n                        plants: [\"Figuiers (nains)\", \"Vigne (grimpante)\", \"Géraniums lierre\", \"Plantes succulentes\"],\n                        description: \"Ces zones peuvent amplifier la chaleur et la sécheresse, choisissez des espèces adaptées.\"\n                    });\n                }\n                if (microclimat.includes('humide') || microclimat.includes('point d\\'eau')) {\n                    recommendations.push({\n                        category: \"Zones Humides\",\n                        plants: [\"Menthe\", \"Prêle\", \"Certaines fougères\", \"Sauge des marais\"],\n                        description: \"Idéal pour les plantes qui apprécient une humidité constante ou un sol humide.\"\n                    });\n                }\n            }\n\n\n            resultDiv.innerHTML = `<h3>Vos Recommandations Botaniques</h3>`;\n            if (recommendations.length === 0) {\n                resultDiv.innerHTML += `<p>Aucune recommandation spécifique pour cette combinaison. Essayez d'ajuster vos paramètres ou contactez notre support pour une analyse personnalisée.</p>`;\n            } else {\n                recommendations.forEach(rec => {\n                    resultDiv.innerHTML += `\n                        <div>\n                            <strong>${rec.category} :</strong>\n                            <p>${rec.plants.join(', ')}.</p>\n                            <p style=\"font-size: 0.85rem; color: #588157;\">${rec.description}</p>\n                        </div>\n                    `;\n                });\n            }\n        });\n    </script>\n<div id=\"qa-smoke-result\" hidden></div>\n<script id=\"farmbuilder-affiliate-helper\">\n(function () {\n  window.__UTILITY_AFFILIATE_MAP = window.__UTILITY_AFFILIATE_MAP || {};\n  document.addEventListener(\"click\", function (event) {\n    const target = event.target.closest(\"[data-affiliate-slot]\");\n    if (!target) return;\n    const slot = target.getAttribute(\"data-affiliate-slot\");\n    const href = window.__UTILITY_AFFILIATE_MAP[slot];\n    if (!href) return;\n    if (target.tagName && target.tagName.toLowerCase() === \"a\") {\n      target.setAttribute(\"href\", href);\n      target.removeAttribute(\"rel\");\n      return;\n    }\n    event.preventDefault();\n    window.open(href, \"_blank\");\n  }, true);\n})();\n</script>\n<script id=\"farmbuilder-functional-qa\">\n(function () {\n  function marker() {\n    let node = document.getElementById(\"qa-smoke-result\");\n    if (node) return node;\n    node = document.createElement(\"div\");\n    node.id = \"qa-smoke-re